# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Postgres connection string). Required to run migrations.
# Example: postgres://postgres:password@db.host.supabase.co:5432/postgres
DATABASE_URL=


# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Groq / AI
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OCR
OCR_SPACE_API_KEY=

# FastAPI / internal
FASTAPI_BASE_URL=http://127.0.0.1:8000
FASTAPI_CALLBACK_URL=http://host.docker.internal:8000
WEBHOOK_SECRET=
LOG_LEVEL=INFO

# n8n
N8N_BASE_URL=
N8N_API_KEY=
N8N_API_AUTH_MODE=x-api-key

# Deployment / Railway variables
# Database connection string (Postgres). Required for migrations and runtime.
# Example: postgres://postgres:password@db.host:5432/postgres
DATABASE_URL=

# Public URL for the backend (used when building callback URLs that n8n will POST to)
BACKEND_PUBLIC_URL=https://backend-production.example.com

# n8n: base url and API key. The backend will use the X-N8N-API-KEY header with this value.
N8N_BASE_URL=https://n8n-production.example.com
N8N_API_KEY=

# Optional: the webhook path on the n8n instance used for triggering workflows
# and the HR-specific webhook URL if set separately.
N8N_WEBHOOK_PATH=execute-workflow
N8N_HR_WEBHOOK_URL=${N8N_BASE_URL}/webhook/${N8N_WEBHOOK_PATH}

# Secret/token used to validate incoming callbacks from n8n.
# The callback sender must include header `X-N8N-Callback-Secret: <value>`.
# If you set a production secret, change this value. Keep it secret in Railway env.
N8N_CALLBACK_SECRET=
# Backwards-compatible alias used by some deploys. Either may be used by the server.
CALLBACK_AUTH_TOKEN=

# Admin key used by /api/admin endpoints
ADMIN_KEY=

# Frontend URL (optional)
FRONTEND_URL=http://localhost:3000


