      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://backend:8000/api/document/extract",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"content_base64\": \"{{ $json.content_base64 || '' }}\",\n  \"filename\": \"{{ $json.filename }}\",\n  \"mime_type\": \"{{ $json.mime_type }}\",\n  \"language\": \"eng\",\n  \"use_ocr_fallback\": true,\n  \"request_id\": \"{{ $json.request_id }}\",\n  \"workflow_type\": \"invoice_processing\",\n  \"step_id\": \"extract_document\"\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "3a7bdcba-59eb-4f42-bf2c-8d7dd7e27e2a",
