        "specifyBody": "json",
        "jsonBody": "{\n  \"workflow_type\": \"Invoice Pipeline\",\n  \"status\": \"started\",\n  \"request_id\": \"{{ $json.request_id || Date.now().toString() }}\",\n  \"submitted_at\": \"{{ $now.toISOString() }}\"\n}",
        "options": {
