      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "38c4af0a-cfca-4eec-a8eb-a4b8b81c9847",
      "name": "Validate Extraction",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        3264,
        176
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"max_tokens\": 400,\n  \"temperature\": 0.0,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Extract invoice fields from the text. Return ONLY valid JSON with keys: vendor_name, invoice_number, invoice_date, due_date, subtotal, tax, total_amount, currency, line_items (array of {description, quantity, unit_price, amount}). Use null for missing fields.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Extract invoice fields from: {{ $json.extracted_text || 'No text extracted' }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "dc79beb7-07ce-4972-8bc3-814a469c54d1",
      "name": "Parse Invoice Fields (LLM)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        3424,
        176
      ]
    },
    {
      "parameters": {
        "jsCode": "const llm = $input.first().json;\nlet fields = {};\ntry {\n  const content = llm.choices?.[0]?.message?.content || '{}';\n  fields = JSON.parse(content);\n} catch(e) {\n  fields = { parse_error: String(e), raw: String(llm).slice(0, 200) };\n}\n// Carry forward context from earlier nodes\nconst ctx = $('Extract Invoice Context').first().json;\nreturn [{ json: {\n  ...fields,\n  filename:   ctx.filename,\n  request_id: ctx.request_id,\n  rule_id:    ctx.rule_id,\n  target_sheet: ctx.target_sheet,\n  processed_at: new Date().toISOString(),\n  status: 'parsed'\n} }];"
      },
      "id": "0a8fb6fd-ae58-4bc5-ab0b-bebaec676e09",
      "name": "Build Invoice Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3584,
        176
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/api/execution-callback",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"request_id\": \"{{ $json.request_id }}\",\n  \"workflow_type\": \"invoice_processing\",\n  \"status\": \"executed\",\n  \"results\": [{\n    \"step_id\": \"invoice_parsed\",\n    \"vendor_name\":     \"{{ $json.vendor_name }}\",\n    \"invoice_number\":  \"{{ $json.invoice_number }}\",\n    \"invoice_date\":    \"{{ $json.invoice_date }}\",\n    \"total_amount\":    \"{{ $json.total_amount }}\",\n    \"currency\":        \"{{ $json.currency }}\",\n    \"filename\":        \"{{ $json.filename }}\"\n  }]\n}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "4cab98a5-9278-46f9-ae1f-cfb076fec017",
      "name": "Store Invoice Result",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        3744,
