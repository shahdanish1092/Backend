        "jsonBody": "{\n  \"workflow_type\": \"Daily Summary Pipeline\",\n  \"status\": \"started\",\n  \"request_id\": \"{{ $json.request_id || Date.now().toString() }}\",\n  \"submitted_at\": \"{{ $now.toISOString() }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
