          "timeout": 30000
        }
      },
      "id": "953ba6bb-8cb1-4189-a9d2-47cfb539f5c1",
      "name": "Fetch Daily Activity",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        2096,
        640
      ]
    },
    {
      "parameters": {
        "jsCode": "const activity = $input.first().json;\nif (!activity || Object.keys(activity).length === 0) {\n  return [{\n    json: {\n      date: new Date().toISOString().split('T')[0],\n      executions: [],\n      calendar_events: [],\n      emails_sent: [],\n      summary: 'No activity data available for today'\n    }\n  }];\n}\nreturn [{\n  json: activity\n}];"
      },
      "id": "c073250f-4062-437c-ae4e-45f3ffda6362",
      "name": "Fallback Empty Activity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2256,
        640
      ]
    },
    {
      "parameters": {
        "url": "=http://backend:8000/api/activity/ai-daily-summary?summary_date={{ $json.date }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "d7145933-8c85-457e-899a-2ccb562538c8",
      "name": "Fetch AI Daily Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        2416,
        640
      ]
    },
    {
      "parameters": {
        "jsCode": "// Backend already ran the LLM — just enrich with pipeline metadata\nconst summary = $input.first().json;\nconst ctx = $('Extract Summary Context').first().json;\n\nreturn [{ json: {\n  ...summary,\n  request_id:   ctx.request_id,\n  pipeline:     'daily_summary',\n  generated_at: summary.generated_at || new Date().toISOString(),\n  status:       summary.health_status === 'Healthy' ? 'success' : 'needs_attention',\n} }];"
      },
      "id": "b337c576-4479-4cbf-a822-8478e1787e4d",
      "name": "Enrich Summary Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2656,
        640
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://backend:8000/api/automation-executions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"workflow_type\": \"Daily Summary Pipeline\",\n  \"status\":        \"{{ $json.status || 'success' }}\",\n  \"request_id\":    \"{{ $json.request_id }}\",\n  \"completed_at\":  \"{{ $now.toISOString() }}\",\n  \"summary\":       \"{{ $json.ai_summary?.slice(0, 200) || 'Daily summary generated' }}\",\n  \"error\":         \"{{ $json.llm_error || '' }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "ca3a1470-ca2e-49c6-98ba-2945521d5451",
      "name": "Log Execution End",
