              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"user_statement\":       \"{{ $json.user_statement }}\",\n  \"documents_source\":     \"{{ $json.documents_source }}\",\n  \"criteria\":             \"{{ $json.criteria }}\",\n  \"ranking_logic\":        \"weighted_scoring\",\n  \"shortlist_limit\":      3,\n  \"hr_email\":             \"hr@company.com\",\n  \"hr_calendar\":          \"primary\",\n  \"timezone\":             \"{{ $json.timezone }}\",\n  \"working_hours_start\":  \"10:00\",\n  \"working_hours_end\":    \"18:00\",\n  \"slot_duration_minutes\": 30,\n  \"slot_gap_minutes\":     15,\n  \"freebusy_lookahead_days\": 7,\n  \"wait_for_completion\":  false,\n  \"wait_timeout_seconds\": 30,\n  \"poll_interval_seconds\": 2,\n  \"attachment_payloads\":  {{ JSON.stringify($json.attachment_payloads || []) }}\n}",
        "options": {
