        1632,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "// If Gmail trigger forwarded attachments as base64, process them directly.\n// Otherwise pass through for hr-simulation to handle.\nconst data = $input.first().json;\nconst attachments = $('Resume Trigger').first().json?.attachments || [];\nconst content_b64 = $('Resume Trigger').first().json?.content_base64;\n\n// Build the attachment list for downstream\nlet att_payloads = attachments;\nif (!att_payloads.length && content_b64) {\n  att_payloads = [{\n    filename: $('Resume Trigger').first().json?.filename || 'resume.pdf',\n    mime_type: $('Resume Trigger').first().json?.mime_type || 'application/pdf',\n    content_base64: content_b64,\n  }];\n}\n\nreturn [{ json: {\n  ...data,\n  attachment_payloads: att_payloads,\n  has_attachments: att_payloads.length > 0,\n  documents_source: att_payloads.length > 0 ? 'trigger://gmail_attachment' : data.documents_source,\n} }];"
      },
      "id": "fb2da679-128e-4f40-aa35-ea2727e1a513",
      "name": "Ingest Attachments (if forwarded)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1856,
        144
      ]
    },
