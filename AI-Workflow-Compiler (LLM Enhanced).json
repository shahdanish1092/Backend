        "jsCode": "// Handles both success output (port 0) and error output (port 1)\n// from the LLM Intent Classifier node\nconst intentResult = $input.first().json;\n\n// Determine workflow_type — use LLM result or fall back to hr_recruitment\nconst workflowType = intentResult.workflow_type || 'hr_recruitment';\nconst intentId = intentResult.intent_id || null;\n\n// Get original payload from Flatten Step\nlet originalPayload = {};\ntry { originalPayload = $('Flatten Step').first().json; } catch(e) {}\n\nreturn [{\n  json: {\n    ...originalPayload,\n    workflow_type: workflowType,\n    intent_id: intentId,\n    clarification_questions: intentResult.clarification_questions || [],\n    llm_intent_used: !intentResult.error,\n    llm_fallback: !!intentResult.error\n  }\n}];"
