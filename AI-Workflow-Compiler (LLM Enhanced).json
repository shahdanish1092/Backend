        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"max_tokens\": 800,\n  \"temperature\": 0.1,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a candidate re-ranker for HR recruitment. Given a list of ranked candidates and job criteria, re-rank them by best fit. Return ONLY valid JSON in this exact format: { \\\"reranked\\\": [ { \\\"candidate_name\\\": \\\"string\\\", \\\"candidate_email\\\": \\\"string or null\\\", \\\"adjusted_score\\\": 0, \\\"fit_reason\\\": \\\"string\\\" } ] }\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Candidates: {{ JSON.stringify($json.ranked_candidates || []) }}\\n\\nJob criteria: {{ $('Build Rank Input').first().json.criteria || 'General professional skills' }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 20000
        }
      },
      "id": "22cbab90-3d20-437f-8b12-e958b7e805f0",
