        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"max_tokens\": 400,\n  \"temperature\": 0.1,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a result normalizer. Given any workflow step result, return ONLY valid JSON with exactly these keys: { \\\"success\\\": boolean, \\\"summary\\\": \\\"one sentence describing what happened\\\", \\\"data\\\": {}, \\\"next_actions\\\": [] }\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Normalize this workflow step result: {{ JSON.stringify($json) }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "7b747fdd-21df-49fe-8061-70d507d628e5",
      "name": "LLM Result Normalizer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3200,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Handles input from EITHER:\n//   A) LLM Result Normalizer (has choices[0].message.content)\n//   B) Shortlist HTTP node directly (has shortlisted array)\nconst item = $input.first().json;\nlet normalized = {};\n\nif (item.choices && item.choices[0]) {\n  // Coming from LLM Result Normalizer\n  try {\n    normalized = JSON.parse(item.choices[0].message.content);\n  } catch(e) {\n    normalized = { success: true, summary: 'Shortlist step completed', data: item, next_actions: [] };\n  }\n} else {\n  // Coming directly from Shortlist HTTP node\n  normalized = {\n    success: item.status === 'completed',\n    summary: 'Shortlisted ' + (item.shortlisted_count || 0) + ' candidates',\n    data: {\n      shortlisted: item.shortlisted || [],\n      shortlisted_count: item.shortlisted_count || 0,\n      top_k: item.top_k || 3\n    },\n    next_actions: ['send_emails', 'schedule_interviews']\n  };\n}\n\nlet workflowType = 'hr_recruitment';\nlet intentId = null;\ntry {\n  workflowType = $('Merge Intent Context').first().json.workflow_type || 'hr_recruitment';\n  intentId = $('Merge Intent Context').first().json.intent_id || null;\n} catch(e) {}\n\nreturn [{\n  json: {\n    ...normalized,\n    workflow_type: workflowType,\n    intent_id: intentId,\n    step_id: 'normalize_shortlist',\n    llm_normalized: !!(item.choices)\n  }\n}];"
      },
      "id": "c6b1dc23-4f6a-49e4-a1fb-ba23ffc83714",
      "name": "Normalize Shortlist Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3424,
        144
      ]
    },
    {
      "parameters": {},
      "id": "2da1d413-2031-42c3-b409-9f2fa3e6db0b",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        3648,
        144
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = items.map(i => i.json);\n\nlet intentId = null;\nlet workflowType = 'hr_recruitment';\nlet llmReranked = false;\ntry { intentId = $('Merge Intent Context').first().json.intent_id; } catch(e) {}\ntry { workflowType = $('Merge Intent Context').first().json.workflow_type; } catch(e) {}\ntry { llmReranked = $('Parse Re-rank Result').first().json.llm_reranked || false; } catch(e) {}\n\nreturn [{\n  json: {\n    status: 'executed',\n    intent_id: intentId,\n    workflow_type: workflowType,\n    results,\n    completed_at: new Date().toISOString(),\n    llm_enhancements: {\n      intent_classified: true,\n      candidates_reranked: llmReranked,\n      result_normalized: true\n    }\n  }\n}];"
      },
