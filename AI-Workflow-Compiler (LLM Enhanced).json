    {
      "parameters": {
        "jsCode": "// Parse LLM re-ranker response — graceful fallback to original ranking\nconst llmResponse = $input.first().json;\nlet originalRanked = {};\ntry { originalRanked = $('Rank Candidates').first().json; } catch(e) {}\n\nlet reranked = [];\ntry {\n  const content = llmResponse.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  reranked = parsed.reranked || parsed.candidates || [];\n} catch(e) {\n  // LLM failed or timed out — use original backend ranking unchanged\n  reranked = [];\n}\n\nreturn [{\n  json: {\n    ...originalRanked,\n    ranked_candidates: reranked.length ? reranked : (originalRanked.ranked_candidates || []),\n    llm_reranked: reranked.length > 0,\n    request_id: originalRanked.request_id,\n    workflow_type: originalRanked.workflow_type || 'hr_recruitment'\n  }\n}];"
      },
